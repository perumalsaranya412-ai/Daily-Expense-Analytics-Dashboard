<!DOCTYPE html>
<html>
<head>
  <title>Expense Dashboard</title>
  <style>
    body { font-family: Arial; padding: 20px; max-width: 700px; margin: auto; }
    input, select, button { padding: 8px; margin: 5px; }
    button { background: #4CAF50; color: white; border: none; cursor: pointer; }
    button:hover { background: #45a049; }
    table { margin-top: 20px; border-collapse: collapse; }
    th { background: #4CAF50; color: white; }
    th, td { padding: 10px; text-align: left; }
    h3 { color: #333; }
  </style>
</head>
<body>
<h2>Daily Expense Analytics Dashboard</h2>

<select id="type">
  <option value="expense">Expense</option>
  <option value="income">Income</option>
</select>
<input id="cat" placeholder="Category">
<input id="amt" type="number" placeholder="Amount">
<button onclick="add()">Add</button>

<h3>Balance: ₹<span id="bal">0</span></h3>
<table border="1" width="100%">
<thead><tr><th>Type</th><th>Category</th><th>Amount</th></tr></thead>
<tbody id="tb"></tbody>
</table>

<h3>Summary</h3><ul id="sum"></ul>

<script>
let tx = JSON.parse(localStorage.getItem('tx')) || [];

function add(){
  let type = document.getElementById('type').value;
  let cat = document.getElementById('cat').value.trim();
  let amt = parseFloat(document.getElementById('amt').value);
  
  if(!cat || !amt || amt <= 0){
    alert('Valid category + amount podu da');
    return;
  }
  
  tx.push({type, cat, amt});
  localStorage.setItem('tx', JSON.stringify(tx)); // Save
  update();
  
  document.getElementById('cat').value = "";
  document.getElementById('amt').value = "";
}
function getBalance(){
  let bal = 0;
  tx.forEach(t => {
    if(t.type == 'income') bal += t.amt;
    else bal -= t.amt;
  });
  return bal;
}
function getSummary(){
  let sum = {};
  tx.forEach(t => {
    if(t.type == 'expense'){
      sum[t.cat] = (sum[t.cat] || 0) + t.amt;
    }
  });
  return sum;
}
function update(){
  // Table update
  let rows = '';
  tx.forEach(t => {
    rows += <tr><td>${t.type}</td><td>${t.cat}</td><td>₹${t.amt}</td></tr>;
  });
  document.getElementById('tb').innerHTML = rows;
  document.getElementById('bal').innerText = getBalance();
  let s = getSummary();
  let list = '';
  for(let k in s){
    list += <li>${k}: ₹${s[k]}</li>;
  }
  document.getElementById('sum').innerHTML = list;
}

update();
</script>
</body>
</html>